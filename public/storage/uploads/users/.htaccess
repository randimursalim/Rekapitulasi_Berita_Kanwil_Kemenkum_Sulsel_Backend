# Secure upload directory for users (Apache 2.2 and 2.4 compatible)
<IfModule mod_authz_core.c>
    <FilesMatch "\.(php|phtml|php3|php4|php5|pl|py|jsp|asp|sh|exe|cgi)$">
        Require all denied
    </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
    <FilesMatch "\.(php|phtml|php3|php4|php5|pl|py|jsp|asp|sh|exe|cgi)$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
</IfModule>

# Prevent directory browsing
Options -Indexes

# Security headers for served assets
<IfModule mod_headers.c>
    Header set X-Content-Type-Options nosniff
</IfModule>
